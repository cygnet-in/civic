/* =====================================================
   Civic Platform Base Theme
===================================================== */

:root {
    --civic-primary: #0056b3;
    --civic-primary-hover: #004494;

    --civic-text: #1f2937;
    --civic-text-light: #6b7280;

    --civic-border: #e5e7eb;
    --civic-bg-soft: #f9fafb;

    --civic-radius: 12px;
}

/* =====================================================
   Layout Containers
===================================================== */

.civic-threads,
.civic-events,
.civic-schedules,
.civic-thread-detail,
.civic-event-detail,
.civic-schedule-detail,
.civic-rep-form {
    max-width: 960px;
    margin: 40px auto;
    padding: 0 20px;
}

/* =====================================================
   Single Column Listings
===================================================== */

.civic-threads,
.civic-events,
.civic-schedules {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

/* =====================================================
   Common Card
===================================================== */

.civic-card {
    background: #fff;
    border: 1px solid var(--civic-border);
    border-radius: var(--civic-radius);
    padding: 28px;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
    transition: all .2s ease;
}

.civic-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,.08);
}

.civic-card__title {
    margin: 0 0 12px;
    color: var(--civic-text);
    line-height: 1.3;
    font-size: 1.75rem;
    font-weight: 600;
}

.civic-card__summary {
    color: var(--civic-text-light);
    line-height: 1.7;
    margin: 0 0 18px;
}

.civic-card__description,
.civic-card__details,
.civic-card__text {
    color: var(--civic-text);
    line-height: 1.8;
    margin: 0 0 24px;
}

.civic-card__description p:last-child,
.civic-card__details p:last-child,
.civic-card__text p:last-child {
    margin-bottom: 0;
}

.civic-card__media {
    margin: 0 0 18px;
}

.civic-card__media img {
    display: block;
    width: 160px;
    height: 108px;
    object-fit: cover;
    border-radius: 8px;
}

.civic-media-gallery {
    margin: 0 0 24px;
}

.civic-media-gallery__primary {
    display: block;
    width: 100%;
    max-height: 520px;
    object-fit: cover;
    border-radius: 8px;
}

.civic-media-gallery__caption {
    margin: 8px 0 0;
    color: var(--civic-text-light);
}

.civic-media-gallery__thumbnails {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
}

.civic-media-gallery__thumbnail {
    width: 72px;
    height: 56px;
    padding: 0;
    border: 1px solid var(--civic-border);
    border-radius: 6px;
    background: #fff;
    overflow: hidden;
    cursor: pointer;
}

.civic-media-gallery__thumbnail img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* =====================================================
   Meta Information
===================================================== */

.civic-card__date,
.civic-card__location,
.civic-card__type,
.civic-card__status {
    color: var(--civic-text-light);
    margin: 0 0 12px;
    font-size: .95rem;
}

/* =====================================================
   Meta Grid
===================================================== */

.civic-card__meta,
.civic-card__custom-fields {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 10px 24px;
    padding: 20px;
    background: var(--civic-bg-soft);
    border-radius: 10px;
    margin: 24px 0;
}

.civic-card__meta dt,
.civic-card__custom-fields dt {
    margin: 0;
    font-size: .78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--civic-text-light);
}

.civic-card__meta dd,
.civic-card__custom-fields dd {
    margin: 0;
    color: var(--civic-text);
}

/* =====================================================
   Buttons
===================================================== */

.civic-card__actions,
.civic-thread-detail__actions,
.civic-events__actions,
.civic-schedules__actions,
.civic-threads__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 20px;
}

.civic-card__actions a,
.civic-thread-detail__actions a,
.civic-events__actions a,
.civic-schedules__actions a,
.civic-threads__actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    padding: 12px 20px;

    background: var(--civic-primary);
    color: #fff;

    border-radius: 8px;

    font-weight: 600;
    text-decoration: none;

    transition: .2s ease;
}

.civic-card__actions a:hover,
.civic-thread-detail__actions a:hover,
.civic-events__actions a:hover,
.civic-schedules__actions a:hover,
.civic-threads__actions a:hover {
    background: var(--civic-primary-hover);
}

/* =====================================================
   Detail Pages
===================================================== */

.civic-thread-detail__content,
.civic-event-detail__content,
.civic-schedule-detail__content {
    margin-bottom: 32px;
}

.civic-thread-detail__title,
.civic-event-detail__title,
.civic-schedule-detail__title {
    font-size: 2.25rem;
}

/* =====================================================
   Public Responses
===================================================== */

/* =========================
   Public Response Cards Fix
========================= */

.civic-thread-detail__public-responses {
    max-width: 960px;
    margin: 40px auto;
}

.civic-thread-detail__public-responses > h2 {
    margin: 0 0 22px;
    font-size: 2rem;
    color: var(--civic-text);
}

.civic-thread-response {
    display: block;
    border: 1px solid var(--civic-border);
    border-radius: var(--civic-radius);
    background: #fff;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
}

.civic-thread-response__name {
    font-size: 1.25rem;
    margin: 0 0 6px;
    color: var(--civic-text);
}

.civic-thread-response__date {
    display: inline-block;
    margin: 0 0 18px;
    font-size: .9rem;
    color: var(--civic-text-light);
}

.civic-thread-response__text {
    margin: 0 0 22px;
    color: var(--civic-text);
    line-height: 1.7;
}

.civic-thread-response__text p {
    margin: 0;
}

