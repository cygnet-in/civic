{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "superb-addons/author-box",
  "version": "0.3.0",
  "title": "Superb About the Author",
  "category": "superb-addons-blocks",
  "icon": "id",
  "description": "Showcase post authors with their avatar, bio, and social media links in a customizable author box.",
  "keywords": [
    "author",
    "author box",
    "about",
    "about author",
    "about the author",
    "biography"
  ],
  "usesContext": ["postId", "postType"],
  "supports": {
    "html": false,
    "align": ["wide", "full", "left", "right"],
    "color": {
      "background": true,
      "gradients": true,
      "text": false,
      "link": false
    },
    "spacing": {
      "margin": true,
      "padding": true
    },
    "shadow": true,
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "__experimentalBorder": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    }
  },
  "textdomain": "superb-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}
