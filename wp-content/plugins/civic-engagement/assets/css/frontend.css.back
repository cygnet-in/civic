/* Mobile */
@media (max-width: 700px) {
    .civic-thread-response {
        padding: 22px;
    }

    .civic-thread-response__custom-fields {
        grid-template-columns: 1fr;
    }
}

/* =====================================================
   Forms
===================================================== */

.civic-form {
    background: #fff;
    border: 1px solid var(--civic-border);
    border-radius: var(--civic-radius);
    padding: 28px;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
}

.civic-form h2 {
    margin-top: 0;
    margin-bottom: 24px;
}

.civic-form form {
    display: grid;
    grid-template-columns: repeat(2,minmax(0,1fr));
    gap: 18px 22px;
}

.civic-form p {
    margin: 0;
}

.civic-form label {
    display: block;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--civic-text);
}

.civic-form input,
.civic-form select,
.civic-form textarea {
    width: 100%;
    padding: 11px 14px;

    border: 1px solid #d1d5db;
    border-radius: 8px;

    font-size: 1rem;
}

.civic-form textarea {
    min-height: 120px;
    resize: vertical;
}

.civic-form p:last-child {
    grid-column: 1 / -1;
}

.civic-form button {
    background: var(--civic-primary);
    color: #fff;

    border: none;
    border-radius: 8px;

    padding: 12px 22px;

    font-weight: 600;
    cursor: pointer;
}

.civic-form button:hover {
    background: var(--civic-primary-hover);
}

/* =====================================================
   Status Styling
===================================================== */

.civic-card__status {
    display: inline-block;
    padding: 6px 10px;
    border-radius: 6px;
    background: #f3f4f6;
    font-weight: 600;
}

/* =====================================================
   Mobile
===================================================== */

@media (max-width: 768px) {

    .civic-threads,
    .civic-events,
    .civic-schedules,
    .civic-thread-detail,
    .civic-event-detail,
    .civic-schedule-detail,
    .civic-rep-form {
        padding: 0 15px;
    }

    .civic-card,
    .civic-form {
        padding: 22px;
    }

    .civic-form form {
        grid-template-columns: 1fr;
    }

    .civic-thread-detail__title,
    .civic-event-detail__title,
    .civic-schedule-detail__title {
        font-size: 1.8rem;
    }

    .civic-card__meta,
    .civic-card__custom-fields {
        display: grid;
        grid-template-columns: minmax(140px, 220px) 1fr;
        gap: 10px 18px;
        padding: 18px;
        background: var(--civic-bg-soft);
        border-radius: 10px;
        margin: 20px 0 24px;
    }
}

.civic-card {
    display: flex;
    gap: 22px;
    align-items: flex-start;
}

/* .civic-card__media {
    width: 72px;
    height: 72px;
    flex: 0 0 72px;
    border-radius: 18px;
    background-color: #f0f7ff;
    background-repeat: no-repeat;
    background-position: center;
    background-size: 36px;
} */

.civic-card__media {
    width: 96px;
    height: 96px;
    flex: 0 0 96px;

    border-radius: 18px;

    background-color: #e8f2ff;
    background-size: 58px;
    background-repeat: no-repeat;
    background-position: center;
}

.civic-threads__item .civic-card__media {
    background-image: url("icons/consultation.png");
}

.civic-events__item .civic-card__media {
    background-image: url("icons/event.png");
}

.civic-schedules__item .civic-card__media {
    background-image: url("icons/schedule.png");
}

.civic-reps__item .civic-card__media {
    background-image: url("icons/representation.png");
}

.civic-card__content {
    flex: 1;
}

@media (max-width: 640px) {
    .civic-card {
        flex-direction: column;
    }
}

/* =========================
   Civic Messages / Alerts
========================= */

.civic-form__message,
.civic-rep-form__message {
    padding: 16px 20px;
    margin: 0 0 24px;
    border-radius: 10px;
    border: 1px solid transparent;
    border-left-width: 5px;
    font-weight: 500;
    line-height: 1.5;
}

.civic-form__message--success,
.civic-rep-form__message--success {
    background: #ecfdf3;
    border-color: #a7f3d0;
    border-left-color: #22c55e;
    color: #166534;
}

.civic-form__message--error,
.civic-rep-form__message--error {
    background: #fef2f2;
    border-color: #fecaca;
    border-left-color: #ef4444;
    color: #991b1b;
}

.civic-form__message--warning,
.civic-rep-form__message--warning {
    background: #fffbeb;
    border-color: #fde68a;
    border-left-color: #f59e0b;
    color: #92400e;
}

.civic-form__message--info,
.civic-rep-form__message--info {
    background: #eff6ff;
    border-color: #bfdbfe;
    border-left-color: #3b82f6;
    color: #1e40af;
}

/* =========================
   Civic Pagination
========================= */

.civic-threads__pagination,
.civic-events__pagination,
.civic-schedules__pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;

    margin: 8px 0 0;
    padding: 18px 20px;

    background: #fff;
    border: 1px solid var(--civic-border);
    border-radius: var(--civic-radius);
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
}

.civic-threads__pagination-current,
.civic-events__pagination-current,
.civic-schedules__pagination-current {
    color: var(--civic-text-light);
    font-weight: 600;
}

.civic-threads__pagination a,
.civic-events__pagination a,
.civic-schedules__pagination a {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    padding: 10px 16px;

    background: var(--civic-primary);
    color: #fff;

    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
}

.civic-threads__pagination a:hover,
.civic-events__pagination a:hover,
.civic-schedules__pagination a:hover {
    background: var(--civic-primary-hover);
}

.civic-threads__pagination-prev::before,
.civic-events__pagination-prev::before,
.civic-schedules__pagination-prev::before {
    content: "← ";
}

.civic-threads__pagination-next::after,
.civic-events__pagination-next::after,
.civic-schedules__pagination-next::after {
    content: " →";
}

@media (max-width: 640px) {
    .civic-threads__pagination,
    .civic-events__pagination,
    .civic-schedules__pagination {
        flex-direction: column;
        align-items: stretch;
        text-align: center;
    }

    .civic-threads__pagination a,
    .civic-events__pagination a,
    .civic-schedules__pagination a {
        width: 100%;
    }
}

/* =========================
   Side Bar
========================= */

.inside-right-sidebar .widget {
    background: #fff;
    border: 1px solid var(--civic-border);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 24px;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
}

.widget-title {
    margin: 0 0 18px;
    padding-bottom: 12px;

    font-size: 1.25rem;
    font-weight: 600;

    color: var(--civic-text);

    border-bottom: 2px solid #e5e7eb;
}

.civic-widget {
    list-style: none;
    padding: 0;
    margin: 0;
}

.civic-widget__item {
    padding: 12px 0;
    border-bottom: 1px solid #f1f5f9;
}

.civic-widget__item:last-child {
    border-bottom: none;
}

.civic-widget__item a {
    display: block;

    color: var(--civic-text);
    text-decoration: none;

    font-weight: 500;
    line-height: 1.5;
}

.civic-widget__item a:hover {
    color: var(--civic-primary);
}

.civic-widget__date {
    display: block;
    margin-top: 4px;

    font-size: .85rem;
    color: var(--civic-text-light);
}

.civic-widget__view-all {
    margin: 18px 0 0;
}

.civic-widget__view-all a {
    display: inline-block;

    padding: 8px 14px;

    border: 1px solid var(--civic-primary);
    border-radius: 6px;

    color: var(--civic-primary);
    text-decoration: none;
    font-weight: 600;
}

.civic-widget__view-all a:hover {
    background: var(--civic-primary);
    color: #fff;
}

/* =========================
   Civic Statistics
========================= */

.civic-statistics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 18px;
    max-width: 960px;
    margin: 40px auto;
    padding: 0 20px;
}

.civic-stat-card {
    padding: 24px;
    background: #fff;
    border: 1px solid var(--civic-border);
    border-radius: var(--civic-radius);
    text-align: center;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
}

.civic-stat-card__number {
    color: var(--civic-primary);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
}

.civic-stat-card__title {
    margin-top: 8px;
    color: var(--civic-text);
    font-weight: 600;
}

.widget_civic_latest_consultations .widget-title::before {
    content: "💬 ";
}

.widget_civic_latest_events .widget-title::before {
    content: "📅 ";
}

.widget_civic_upcoming_schedules .widget-title::before {
    content: "🗓️ ";
}
